        </a>
      ))}
      <a href="https://wa.me/34678871916" target="_blank" class="btn-wa-header" style="margin-left:auto;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        WhatsApp
      </a>
    </div>
    <!-- nav links -->
    {nav.map(n => (
      <>
        <a href={n.href} class:list={['mob-nav-link', { active: isActive(n.href) }]}>{n.label}</a>
        {n.children && n.children.map((c: {href:string,label:string}) => (
          <a href={c.href} class:list={['mob-nav-child', { active: isActive(c.href) }]}>↳ {c.label}</a>
        ))}
      </>
    ))}
  </div>
</div>

<main><slot /></main>

<!-- ═══ FOOTER ═══════════════════════════════════════════════════ -->
<footer>
  <div class="footer-inner">
    <div class="footer-col">
      <div class="footer-logo"><img src="/ddx-logo.png" alt="DDX Digital Dental Xperts" style="height:36px;object-fit:contain;filter:brightness(0) invert(1);" /></div>
      <p class="footer-desc">Digital Guided Implant Surgery Immersion Program.<br/>21.02.2027 – 27.02.2027 · Fortaleza, Brasil.</p>
    </div>
    <div class="footer-col">
      <div class="footer-heading">{lang === 'en' ? 'Quick links' : 'Accesos rápidos'}</div>
      <ul class="footer-links">
        {nav.slice(0,6).map(n => <li><a href={n.href}>{n.label}</a></li>)}
      </ul>
    </div>
    <div class="footer-col">
      <div class="footer-heading">{lang === 'en' ? 'Contact' : 'Contacto'}</div>
      <p style="font-size:.82rem;color:#94a3b8;line-height:1.8;">📞 +34 678 871 916<br/>✉ edu@digitaldentaxperts.com<br/>👤 Eduardo Burger</p>
      <a href="https://wa.me/34678871916" target="_blank" class="btn-wa-footer">💬 WhatsApp</a>
    </div>
  </div>
  <div style="background:#fff;padding:24px;display:flex;align-items:center;justify-content:center;gap:48px;flex-wrap:wrap;">
    <img src="/ddx-logo.png" alt="DDX Digital Dental Xperts" style="height:64px;object-fit:contain;border-radius:6px;" />
    <img src="/pptx_images/logo-straumann.png.png" alt="Straumann Group" style="height:30px;object-fit:contain;" />
    <img src="/pptx_images/logo-clinicare.png.png" alt="CliniCare Training" style="height:44px;object-fit:contain;" />
  </div>
  <div class="footer-bottom">© 2027 DDX · CliniCare Training · NACAR Clínicas Dentales</div>
</footer>

<!-- WhatsApp FAB -->
<a href="https://wa.me/34678871916" target="_blank" class="wa-fab">
  <svg width="26" height="26" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
</a>

<!-- ═══ AVAILABLE SPOTS POPUP ════════════════════════════════════ -->
<div id="spots-overlay">
  <div id="spots-modal">
    <button id="spots-close" aria-label="Cerrar">×</button>
    <div style="font-size:2.6rem;margin-bottom:10px;">🎓</div>
    <div class="eyebrow" style="margin-bottom:14px;">
      {lang === 'en' ? 'Available places' : lang === 'fr' ? 'Places disponibles' : 'Plazas disponibles'}
    </div>
    <div id="spots-count">—</div>
    <div style="font-size:.84rem;color:var(--sl500);margin-top:4px;margin-bottom:10px;">
      {lang === 'en' ? 'open spots remaining' : lang === 'fr' ? 'places encore disponibles' : 'plazas libres restantes'}
    </div>
    <div id="spots-bar-wrap">
      <div id="spots-bar-fill"></div>
    </div>
    <a id="spots-cta" href={lang === 'en' ? '/en/registration' : lang === 'fr' ? '/fr/inscription' : '/inscripcion'} class="btn btn-sky btn-lg" style="width:100%;justify-content:center;margin-bottom:12px;">
      {lang === 'en' ? 'Apply now →' : lang === 'fr' ? "S'inscrire →" : 'Inscribirme →'}
    </a>
    <p style="font-size:.72rem;color:var(--sl400);">
      {lang === 'en' ? 'Limited places · First come, first served' : lang === 'fr' ? 'Places limitées · Premier arrivé, premier servi' : 'Cupo limitado · Por orden de inscripción'}
    </p>
  </div>
</div>

<script>
(async () => {
  if (localStorage.getItem('spotsShown')) return;
  try {
    const data = await fetch('/spots.json').then(r => r.json());
    const { available, total } = data;

    const countEl = document.getElementById('spots-count');
    const fillEl  = document.getElementById('spots-bar-fill');
    const overlay = document.getElementById('spots-overlay');

    if (!countEl || !fillEl || !overlay) return;

    if (available <= 0) {
      countEl.textContent = '0';
      countEl.style.color = '#dc2626';
      fillEl.style.width = '100%';
      fillEl.style.background = '#dc2626';
    } else {
      countEl.textContent = String(available);
      const pct = Math.round(((total - available) / total) * 100);
      setTimeout(() => { fillEl.style.width = pct + '%'; }, 200);
    }

    setTimeout(() => { overlay.classList.add('visible'); }, 1500);

    const close = () => {
      overlay.classList.remove('visible');
      localStorage.setItem('spotsShown', '1');
    };
    document.getElementById('spots-close')?.addEventListener('click', close);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
  } catch (_) {}
})();
</script>

<!-- ═══ AI CHAT ASSISTANT ════════════════════════════════════════ -->
<button id="chat-fab" aria-label={lang === 'en' ? 'AI Assistant' : lang === 'fr' ? 'Assistant IA' : 'Asistente IA'}>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
  </svg>
  <span id="chat-fab-label">{lang === 'en' ? 'AI Assistant' : lang === 'fr' ? 'Assistant IA' : 'Asistente IA'}</span>
</button>

<div id="chat-panel" role="dialog" aria-label="Chat">
  <div id="chat-header">
    <div style="display:flex;align-items:center;gap:10px;">
      <div id="chat-avatar">🤖</div>
      <div>
        <div style="font-weight:800;font-size:.88rem;color:#fff;">
          {lang === 'en' ? 'DGIS Assistant' : lang === 'fr' ? 'Assistant DGIS' : 'Asistente DGIS'}
        </div>
        <div style="font-size:.68rem;color:rgba(255,255,255,.7);">
          {lang === 'en' ? 'Ask me anything about the programme' : lang === 'fr' ? 'Posez-moi vos questions' : 'Pregúntame lo que quieras'}
        </div>
      </div>
    </div>
    <button id="chat-close" aria-label="Cerrar">×</button>
  </div>

  <div id="chat-messages">
    <div class="chat-msg chat-msg-ai">
      <div class="chat-bubble">
        {lang === 'en'
          ? '👋 Hello! I\'m the DGIS Fortaleza 2026 assistant. How can I help you today?'
          : lang === 'fr'
          ? '👋 Bonjour ! Je suis l\'assistant du programme DGIS Fortaleza 2026. Comment puis-je vous aider ?'
          : '👋 ¡Hola! Soy el asistente del programa DGIS Fortaleza 2026. ¿En qué puedo ayudarte?'}
      </div>
    </div>
  </div>

  <div id="chat-input-area">
    <input id="chat-input" type="text"
      placeholder={lang === 'en' ? 'Type your question…' : lang === 'fr' ? 'Posez votre question…' : 'Escribe tu pregunta…'}
      autocomplete="off" />
    <button id="chat-send" aria-label="Enviar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>
  </div>
  <div id="chat-footer">Powered by Claude · Anthropic</div>
</div>

<script>
// ── Mobile hamburger ────────────────────────────────────────────
(() => {
  const btn = document.getElementById('hamburger');
  const overlay = document.getElementById('mobile-nav');
  if (!btn || !overlay) return;

  const open  = () => { btn.classList.add('open'); overlay.classList.add('open'); btn.setAttribute('aria-expanded','true'); document.body.style.overflow='hidden'; };
  const close = () => { btn.classList.remove('open'); overlay.classList.remove('open'); btn.setAttribute('aria-expanded','false'); document.body.style.overflow=''; };
  const toggle = () => btn.classList.contains('open') ? close() : open();

  btn.addEventListener('click', toggle);
  // close when clicking the backdrop (not the inner panel)
  overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
  // close when any mobile nav link is clicked
  overlay.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
})();
</script>

<script define:vars={{ lang }}>
(() => {
  const fab      = document.getElementById('chat-fab');
  const panel    = document.getElementById('chat-panel');
  const closeBtn = document.getElementById('chat-close');
  const input    = document.getElementById('chat-input');
  const sendBtn  = document.getElementById('chat-send');
  const messages = document.getElementById('chat-messages');

  if (!fab || !panel || !input || !sendBtn || !messages) return;

  let history = [];
  let open = false;

  // Toggle panel
  const toggle = () => {
    open = !open;
    panel.classList.toggle('chat-open', open);
    fab.classList.toggle('chat-fab-open', open);
    if (open) setTimeout(() => input.focus(), 100);
  };
  fab.addEventListener('click', toggle);
  closeBtn?.addEventListener('click', toggle);

  // Append message bubble
  const addMsg = (role, text) => {
    const div = document.createElement('div');
    div.className = `chat-msg chat-msg-${role === 'user' ? 'user' : 'ai'}`;
    const bubble = document.createElement('div');
    bubble.className = 'chat-bubble';
    bubble.textContent = text;
    div.appendChild(bubble);
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
    return div;
  };

  // Typing indicator
  const addTyping = () => {
    const div = document.createElement('div');
    div.className = 'chat-msg chat-msg-ai';
    div.id = 'chat-typing';
    div.innerHTML = '<div class="chat-bubble chat-typing-dots"><span></span><span></span><span></span></div>';
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  };
  const removeTyping = () => document.getElementById('chat-typing')?.remove();

  // Send message
  const send = async () => {
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    sendBtn.disabled = true;

    addMsg('user', text);
    addTyping();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, lang, history }),
      });
      const data = await res.json();
      removeTyping();
      const reply = data.reply || (lang === 'fr' ? 'Désolé, une erreur est survenue.' : lang === 'en' ? 'Sorry, something went wrong.' : 'Lo siento, hubo un error.');
      addMsg('ai', reply);
      history.push({ role: 'user', content: text });
      history.push({ role: 'assistant', content: reply });
    } catch {
      removeTyping();
      addMsg('ai', lang === 'fr' ? 'Désolé, une erreur est survenue.' : lang === 'en' ? 'Sorry, something went wrong.' : 'Lo siento, hubo un error.');
    }

    sendBtn.disabled = false;
    input.focus();
  };

  sendBtn.addEventListener('click', send);
  input.addEventListener('keydown', (e) => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); } });
})();
</script>

<style is:global>
