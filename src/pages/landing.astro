---
// Landing / Entry page for DGIS Fortaleza 2026
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DGIS Fortaleza 2026 – Digital Guided Implant Surgery</title>
  <meta name="description" content="Programa de Inmersión en Cirugía de Implantes Guiada Digital – Fortaleza, Brasil, 21.02.2027 – 27.02.2027" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Background image overlay -->
  <div class="bg-overlay"></div>

  <!-- Main content -->
  <div class="page">

    <!-- Top bar -->
    <header class="topbar">
      <div class="logo">
        <span class="logo-dgis">DGIS</span>
        <span class="logo-sep">·</span>
        <span class="logo-sub">Fortaleza 2026</span>
      </div>
      <div class="supported">
        <img src="/pptx_images/logo-clinicare.png.png" alt="CliniCare Training" class="partner-logo" />
      </div>
    </header>

    <!-- Hero -->
    <main class="hero">
      <div class="hero-inner">

        <div class="badge-row">
          <span class="badge">6 – 13 Nov 2026</span>
          <span class="badge badge-gold">12 plazas máx.</span>
        </div>

        <h1 class="headline">
          Digital Guided<br/>
          <span class="headline-accent">Implant Surgery</span>
        </h1>

        <p class="tagline">
          Inmersión quirúrgica de alto nivel en Fortaleza, Brasil.<br class="hide-xs"/>
          Cirugías reales · Planificación 3D · Facultad internacional.
        </p>

        <!-- Key stats -->
        <div class="stats">
          <div class="stat">
            <span class="stat-n">8</span>
            <span class="stat-l">días intensivos</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-n">12</span>
            <span class="stat-l">participantes</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-n">3</span>
            <span class="stat-l">directores</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-n">4K</span>
            <span class="stat-l">retransmisión</span>
          </div>
        </div>

        <!-- CTAs -->
        <div class="cta-group">
          <a href="/" class="btn-enter">
            Entrar al programa
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <div class="lang-row">
            <a href="/en/" class="btn-lang">🇺🇸 English</a>
            <a href="/fr/" class="btn-lang">🇫🇷 Français</a>
          </div>
        </div>

        <!-- WhatsApp contact -->
        <a href="https://wa.me/34678871916" target="_blank" rel="noopener" class="wa-line">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Consultar por WhatsApp · +34 678 871 916
        </a>

      </div>
    </main>

    <!-- Bottom footer -->
    <footer class="foot">
      <span>CliniCare Training · Fortaleza, Ceará, Brasil</span>
      <span class="foot-sep">·</span>
      <span>Organizado por NACAR Clínicas Dentales</span>
    </footer>

  </div>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; overflow-x: hidden; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: #0c1a2e;
    color: #fff;
    min-height: 100vh;
    position: relative;
  }

  /* Background image */
  .bg-overlay {
    position: fixed;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(2,30,60,.92) 0%, rgba(1,60,100,.80) 50%, rgba(0,20,50,.93) 100%),
      url('/pptx_images/fortaleza-hero2.jpg.jpg') center/cover no-repeat;
    z-index: 0;
  }

  .page {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* TOP BAR */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 40px;
    border-bottom: 1px solid rgba(255,255,255,.08);
  }
  .logo { display: flex; align-items: baseline; gap: 8px; }
  .logo-dgis { font-size: 1.4rem; font-weight: 900; color: #38bdf8; letter-spacing: -1px; }
  .logo-sep { color: rgba(255,255,255,.3); font-size: 1rem; }
  .logo-sub { font-size: .65rem; font-weight: 700; color: rgba(255,255,255,.5); text-transform: uppercase; letter-spacing: 1.5px; }
  .partner-logo { height: 32px; object-fit: contain; filter: brightness(0) invert(1); opacity: .6; }

  /* HERO */
  .hero {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 24px;
  }
  .hero-inner {
    max-width: 680px;
    width: 100%;
    text-align: center;
  }

  /* Badges */
  .badge-row { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-bottom: 28px; }
  .badge {
    display: inline-block;
    font-size: .65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.8px;
    padding: 5px 14px;
    border-radius: 20px;
    border: 1px solid rgba(56,189,248,.4);
    color: #7dd3fc;
    background: rgba(14,165,233,.12);
  }
  .badge-gold {
    border-color: rgba(251,191,36,.4);
    color: #fcd34d;
    background: rgba(251,191,36,.1);
  }

  /* Headline */
  .headline {
    font-size: clamp(2.6rem, 7vw, 5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -2px;
    color: #fff;
    margin-bottom: 20px;
  }
  .headline-accent { color: #38bdf8; }

  /* Tagline */
  .tagline {
    font-size: clamp(.9rem, 2vw, 1.08rem);
    color: rgba(255,255,255,.65);
    line-height: 1.7;
    margin-bottom: 36px;
  }

  /* Stats row */
  .stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 40px;
    flex-wrap: wrap;
    row-gap: 16px;
  }
  .stat { text-align: center; padding: 0 24px; }
  .stat-n { display: block; font-size: 2rem; font-weight: 900; color: #38bdf8; line-height: 1; }
  .stat-l { display: block; font-size: .6rem; font-weight: 600; color: rgba(255,255,255,.45); text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }
  .stat-divider { width: 1px; height: 36px; background: rgba(255,255,255,.12); flex-shrink: 0; }

  /* CTA group */
  .cta-group { display: flex; flex-direction: column; align-items: center; gap: 16px; margin-bottom: 28px; }

  .btn-enter {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #0ea5e9;
    color: #fff;
    font-size: 1.05rem;
    font-weight: 700;
    padding: 16px 36px;
    border-radius: 12px;
    text-decoration: none;
    transition: background .2s, transform .15s, box-shadow .2s;
    box-shadow: 0 8px 32px rgba(14,165,233,.35);
  }
  .btn-enter:hover {
    background: #0284c7;
    transform: translateY(-2px);
    box-shadow: 0 14px 40px rgba(14,165,233,.45);
  }

  .lang-row { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
  .btn-lang {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: .82rem;
    font-weight: 600;
    color: rgba(255,255,255,.7);
    border: 1px solid rgba(255,255,255,.2);
    border-radius: 8px;
    padding: 8px 18px;
    text-decoration: none;
    transition: all .15s;
  }
  .btn-lang:hover { border-color: #38bdf8; color: #38bdf8; background: rgba(56,189,248,.08); }

  /* WhatsApp line */
  .wa-line {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: .78rem;
    font-weight: 600;
    color: #4ade80;
    text-decoration: none;
    transition: color .15s;
  }
  .wa-line:hover { color: #86efac; }

  /* Footer */
  .foot {
    padding: 16px 40px;
    border-top: 1px solid rgba(255,255,255,.08);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: .7rem;
    color: rgba(255,255,255,.3);
    flex-wrap: wrap;
    text-align: center;
  }
  .foot-sep { opacity: .4; }

  /* Mobile */
  @media (max-width: 600px) {
    .topbar { padding: 16px 20px; }
    .partner-logo { height: 24px; }
    .hero { padding: 28px 20px; }
    .stat { padding: 0 14px; }
    .stat-n { font-size: 1.6rem; }
    .stat-divider { height: 28px; }
    .btn-enter { font-size: .95rem; padding: 14px 28px; width: 100%; justify-content: center; }
    .foot { padding: 14px 20px; }
    .hide-xs { display: none; }
  }
</style>
