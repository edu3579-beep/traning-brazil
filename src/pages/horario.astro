---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Horario – DGIS Fortaleza 2026" lang="es">

<div class="sec-dark" style="padding:52px 24px 48px;">
  <div class="container" style="padding:0;">
    <span class="eyebrow-white">Organización semanal</span>
    <h1 class="page-h1-white" style="margin-top:10px;">Horario del programa</h1>
    <div class="gold-bar"></div>
    <p class="lead-white" style="max-width:600px;">Fortaleza, Brasil · 6–13 Noviembre 2026. Siete días de inmersión quirúrgica completa.</p>
  </div>
</div>

<div class="sec-white">
  <div class="section">
    <div style="border:1.5px solid var(--sky100);border-radius:14px;overflow:hidden;margin-bottom:48px;">

      <div class="tl-item">
        <div class="tl-day" style="background:var(--sky900);">SÁB<span style="font-size:1.1rem;font-weight:900;display:block;">6</span>NOV</div>
        <div class="tl-body">
          <h4>🛬 Llegada a Fortaleza</h4>
          <div class="tl-row"><span class="tl-time">Todo el día</span><span>Traslado libre en taxi al hotel desde el aeropuerto. Si se forma grupo desde España, viaje conjunto desde Madrid. Datos del hotel al inscribirse.</span></div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-day" style="background:var(--sky700);">DOM<span style="font-size:1.1rem;font-weight:900;display:block;">7</span>NOV</div>
        <div class="tl-body">
          <h4>🌴 Día libre + Reunión general</h4>
          <div class="tl-row"><span class="tl-time">Mañana</span><span>Excursión opcional por Fortaleza</span></div>
          <div class="tl-row"><span class="tl-time">19:00</span><span>Reunión general: funcionamiento del curso y de la clínica</span></div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-day" style="background:var(--sky800);">LUN<span style="font-size:1.1rem;font-weight:900;display:block;">8</span>NOV</div>
        <div class="tl-body">
          <h4>🔬 Jornada quirúrgica completa <span class="badge-basic" style="margin-left:8px;">Implantología Guiada</span></h4>
          <div class="tl-row"><span class="tl-time">07:00</span><span>Recogida en el hotel</span></div>
          <div class="tl-row"><span class="tl-time">08:00</span><span>Presentación del curso — personal, auxiliares y profesores</span></div>
          <div class="tl-row"><span class="tl-time">09:00</span><span>Presentación de casos clínicos (alumnos)</span></div>
          <div class="tl-row"><span class="tl-time">10:00</span><span>1ª tanda de cirugía</span></div>
          <div class="tl-row"><span class="tl-time">12:00</span><span>2ª tanda · Comida (cada pareja al finalizar su 2ª tanda, 12:00–14:00)</span></div>
          <div class="tl-row"><span class="tl-time">14:00</span><span>3ª tanda de cirugía</span></div>
          <div class="tl-row"><span class="tl-time">16:00</span><span>4ª tanda de cirugía</span></div>
          <div class="tl-row"><span class="tl-time">18:00</span><span>Regreso al hotel</span></div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-day" style="background:var(--sky800);">MAR<span style="font-size:1.1rem;font-weight:900;display:block;">9</span>NOV</div>
        <div class="tl-body">
          <h4>🔬 Jornada quirúrgica completa <span class="badge-basic" style="margin-left:8px;">Implantología Guiada</span></h4>
          <div class="tl-row"><span class="tl-time">08:00</span><span>Recogida en el hotel</span></div>
          <div class="tl-row"><span class="tl-time">09:00</span><span>Presentación de casos clínicos (alumnos)</span></div>
          <div class="tl-row"><span class="tl-time">10:00</span><span>1ª tanda · 12:00 2ª tanda · 14:00 3ª tanda · 16:00 4ª tanda</span></div>
          <div class="tl-row"><span class="tl-time">18:00</span><span>Regreso al hotel</span></div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-day" style="background:var(--sky600);">MIÉ<span style="font-size:1.1rem;font-weight:900;display:block;">10</span>NOV</div>
        <div class="tl-body">
          <h4>🔷 OneDay OnePiece + Tarde libre <span class="badge-mid" style="margin-left:8px;">Carga Inmediata</span></h4>
          <div class="tl-row"><span class="tl-time">08:00</span><span>Recogida en el hotel</span></div>
          <div class="tl-row"><span class="tl-time">09:00</span><span>Presentación de casos</span></div>
          <div class="tl-row"><span class="tl-time">10:00</span><span>1ª tanda — Cirugía Guiada con Carga Inmediata (OneDay OnePiece)</span></div>
          <div class="tl-row"><span class="tl-time">Tarde</span><span>🌴 Tarde libre para explorar Fortaleza</span></div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-day" style="background:var(--sky800);">JUE<span style="font-size:1.1rem;font-weight:900;display:block;">11</span>NOV</div>
        <div class="tl-body">
          <h4>🦷 Jornada All-on-Four <span class="badge-advanced" style="margin-left:8px;">Avanzado</span></h4>
          <div class="tl-row"><span class="tl-time">08:00</span><span>Recogida en el hotel</span></div>
          <div class="tl-row"><span class="tl-time">09:00</span><span>Presentación de casos clínicos (alumnos)</span></div>
          <div class="tl-row"><span class="tl-time">10:00</span><span>1ª tanda — Cirugías All-on-Four</span></div>
          <div class="tl-row"><span class="tl-time">14:00</span><span>3ª tanda · 16:00 4ª tanda</span></div>
          <div class="tl-row"><span class="tl-time">18:00</span><span>Regreso al hotel</span></div>
        </div>
      </div>

      <div class="tl-item">
        <div class="tl-day" style="background:var(--green);">VIE<span style="font-size:1.1rem;font-weight:900;display:block;">12</span>NOV</div>
        <div class="tl-body">
          <h4>🏆 All-on-Four · Fin de Curso <span class="badge-advanced" style="margin-left:8px;">Diploma</span></h4>
          <div class="tl-row"><span class="tl-time">08:00</span><span>Recogida en el hotel</span></div>
          <div class="tl-row"><span class="tl-time">09:00</span><span>Colocación All-on-Four (alumnos)</span></div>
          <div class="tl-row"><span class="tl-time">14:00</span><span>🎓 Comida Fin de Curso + Entrega de Diplomas</span></div>
          <div class="tl-row"><span class="tl-time">16:00</span><span>Regreso al hotel · 🌴 Tarde libre</span></div>
        </div>
      </div>

      <div class="tl-item" style="border-bottom:none;">
        <div class="tl-day" style="background:var(--sl700);">SÁB<span style="font-size:1.1rem;font-weight:900;display:block;">13</span>NOV</div>
        <div class="tl-body">
          <h4>✈️ Salida / Regreso de participantes</h4>
          <div class="tl-row"><span class="tl-time">Todo el día</span><span>Traslado libre al aeropuerto</span></div>
        </div>
      </div>
    </div>

    <div class="grid-2" style="gap:24px;">
      <div class="cta-banner" style="grid-template-columns:1fr;">
        <div>
          <h3 style="font-weight:800;font-size:1.05rem;color:var(--sky900);margin-bottom:6px;">📄 Descarga el programa completo</h3>
          <p style="font-size:.84rem;color:var(--sl500);margin-bottom:18px;">Horarios completos y detalles logísticos en PDF.</p>
          <a href="/descargar" class="btn btn-dark">⬇ Descargar PDF</a>
        </div>
      </div>
      <div class="cta-banner" style="grid-template-columns:1fr;">
        <div>
          <h3 style="font-weight:800;font-size:1.05rem;color:var(--sky900);margin-bottom:6px;">¿Tienes preguntas?</h3>
          <p style="font-size:.84rem;color:var(--sl500);margin-bottom:18px;">Contacta con Eduardo Burger directamente por WhatsApp.</p>
          <a href="https://wa.me/34651039967" target="_blank" class="btn btn-wa">💬 WhatsApp</a>
        </div>
      </div>
    </div>
  </div>
</div>
</Layout>
