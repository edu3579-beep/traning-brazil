---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Horaire – DDX Fortaleza 2026" lang="fr">
<div class="sec-dark" style="padding:36px 24px 32px;">
  <div class="container" style="padding:0;">
    <span class="eyebrow-white">Planning</span>
    <h1 class="page-h1-white" style="margin-top:8px;">Horaire du programme</h1>
    <div class="gold-bar"></div>
    <p class="lead-white" style="max-width:560px;">Calendrier journalier du programme d'immersion chirurgicale — 21 au 27 février 2027.</p>
  </div>
</div>
<div class="sec-white">
  <div class="section">
    {[
      { day:'Jour 1', date:'6 Nov.', title:'Arrivée & Orientation', items:['Accueil et check-in à CliniCare Training','Présentation des directeurs et du programme','Installation des logiciels et calibrage','Dîner de bienvenue'] },
      { day:'Jour 2', date:'7 Nov.', title:'Planification Numérique', items:['Cours théorique : flux de travail numérique','Atelier EXocad & Exoplan','Analyse des cas patients','Conception des guides chirurgicaux'] },
      { day:'Jour 3', date:'8 Nov.', title:'Protocole Implantologie Guidée', items:['Révision des plans chirurgicaux','Chirurgie guidée supervisée sur patients','Streaming 4K en direct en auditorium','Analyse planifié/exécuté'] },
      { day:'Jour 4', date:'9 Nov.', title:'Protocole OneDay OnePiece', items:['Cours théorique : implants monoblocs','Planification et réalisation chirurgicale','Supervision directe — Dr. Méndez & Dr. Gonzales','Débriefing clinique de fin de journée'] },
      { day:'Jour 5', date:'10 Nov.', title:'Protocole All-on-Four', items:['Théorie : réhabilitation totale guidée','Chirurgie All-on-Four sur patients','Supervision Prof. Assis Filipe','Analyse de précision et résultats'] },
      { day:'Jour 6', date:'11 Nov.', title:'Cas Avancés & Révision', items:['Cas complexes : régénération osseuse guidée','Révision des compétences acquises','Préparation aux certifications','Soirée culturelle à Fortaleza'] },
      { day:'Jour 7', date:'12 Nov.', title:'Évaluation & Certification', items:['Évaluation finale des compétences cliniques','Remise des diplômes accrédités','Cérémonie de clôture du programme','Départs'] },
    ].map(d => (
      <div class="tl-item">
        <div class="tl-day"><span>{d.day}</span><span style="font-size:.65rem;opacity:.8;">{d.date}</span></div>
        <div class="tl-body">
          <h4>{d.title}</h4>
          {d.items.map(i => <div class="tl-row"><span class="tl-time">›</span><span>{i}</span></div>)}
        </div>
      </div>
    ))}
    <div class="cta-banner" style="margin-top:36px;">
      <div>
        <p style="font-weight:700;color:var(--sky900);margin-bottom:4px;">⬇ Télécharger le programme complet</p>
        <p style="font-size:.82rem;color:var(--sl500);">Calendrier détaillé et informations logistiques en PDF.</p>
      </div>
      <a href="/downloads/DDX-Fortaleza-2026-Programa.pdf" download class="btn btn-sky btn-lg">⬇ Télécharger PDF</a>
    </div>
  </div>
</div>
</Layout>
