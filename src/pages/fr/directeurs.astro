---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Direction – DGIS Fortaleza 2026" lang="fr">

<div class="sec-dark" style="padding:36px 24px 32px;">
  <div class="container" style="padding:0;">
    <span class="eyebrow-white">Équipe pédagogique</span>
    <h1 class="page-h1-white" style="margin-top:8px;">Direction du programme</h1>
    <div class="gold-bar"></div>
    <p class="lead-white" style="max-width:560px;">Une équipe de référence internationale en implantologie guidée numérique et chirurgie orale avancée.</p>
  </div>
</div>

<div class="sec-white">
  <div class="section">

    <!-- Dr. Juan Méndez -->
    <div class="director-card" style="border-bottom:1.5px solid var(--sky100);padding-bottom:36px;margin-bottom:36px;">
      <div class="img-frame director-photo">
        <img src="/pptx_images/image23.jpeg" alt="Dr. Juan Méndez" style="width:100%;height:100%;object-fit:cover;object-position:center top;" />
      </div>
      <div class="director-bio">
        <div class="dir-badge" style="color:var(--sky700);background:var(--sky50);border-color:var(--sky200);">Directeur du Programme</div>
        <h2 class="dir-name">Dr. Juan Méndez</h2>
        <p class="dir-sub">Implantologie · Madrid, Espagne</p>
        <div class="sky-bar"></div>
        <p class="dir-section-label" style="color:var(--sky700);">Formation académique</p>
        <ul class="dir-list">
          {[
            'Chirurgien-Dentiste, Universidad Autónoma de Santo Domingo',
            'Master en Implantologie et Réhabilitation Orale — ESORIB, Madrid',
            'Diplôme en Parodontologie et Implants — Clínica Gingiva, Madrid',
            'Diplôme Universitaire en Implantologie Orale et Maxillo-Faciale — Paris XII',
            'Expert en Chirurgie Plastique Parodontale — Prof. Massimo de Sanctis, Barcelone',
            'Expert en Régénération Osseuse — Prof. Carlo Tinti, Italie',
            'Ex-collaborateur du Master en Implantologie — Université Internationale de Catalogne',
            'Ex-directeur du Programme International d\'Implantologie — CIDESID, Barcelone 2000–2020',
          ].map(i => (
            <li><span class="dot" style="background:var(--sky600);"></span>{i}</li>
          ))}
        </ul>
        <p class="dir-section-label" style="color:var(--sky700);">Spécialisation clinique</p>
        <ul class="dir-chips">
          {['Chirurgie guidée numérique 3D','Mise en charge immédiate All-on-Four','Régénération osseuse guidée (GBR)','Chirurgie plastique parodontale'].map(i => (
            <li>{i}</li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Dr. Manuel Gonzales -->
    <div class="director-card" style="border-bottom:1.5px solid var(--sky100);padding-bottom:36px;margin-bottom:36px;">
      <div class="img-frame director-photo">
        <img src="/pptx_images/mendez-portrait2.jpg" alt="Dr. Manuel Gonzales" style="width:100%;height:100%;object-fit:cover;object-position:center top;" />
      </div>
      <div class="director-bio">
        <div class="dir-badge" style="color:var(--sky700);background:var(--sky50);border-color:var(--sky200);">Directeur du Programme</div>
        <h2 class="dir-name">Dr. Manuel Gonzales</h2>
        <p class="dir-sub">Odontologie · Murcie, Espagne</p>
        <div class="sky-bar"></div>
        <p class="dir-section-label" style="color:var(--sky700);">Formation académique</p>
        <ul class="dir-list">
          {[
            'Licence en Odontologie, Faculté de Médecine, Murcie (2001)',
            'Master en Implantologie et Prothèse — Centro Internacional de Estudios Superiores de Implantología Dental, Universidad Católica de Santo Domingo. Major de promotion (2002–2003)',
            'Recherche & développement Implant Tricortical Excalibur (2004–2005) — Conférencier, SCDO Científica, Barcelone',
            'Master en Implantologie Orale et Prothèse Implanto-assistée — Prof. Dr. Raúl Caffsse & Prof. Dr. Jorge Galante, 300 hrs., Elche (2007–2008)',
            'Master en Vieillissement : Santé, Universidad de Murcia (2015)',
            'Spécialiste en Esthétique Péribuccale — UCAM, Universidad Católica San Antonio, Murcie (2016)',
            'Master en Occlusion et Réhabilitation Orale — Prof. Dr. Aníbal Alonso',
            'Expert en Planification 3D et Chirurgie Guidée — Formación Dental Avanzada C3D, Dr. Xulio Pouso',
            'Expert EXocasd-Exoplan (en ligne) — UCAM, Dr. Pérez GiuGovaz',
          ].map(i => (
            <li><span class="dot" style="background:var(--sky600);"></span>{i}</li>
          ))}
        </ul>
        <p class="dir-section-label" style="color:var(--sky700);">Spécialisation clinique</p>
        <ul class="dir-chips">
          {['Implantologie guidée numérique','Chirurgie guidée 3D','Réhabilitation orale et implantaire','Esthétique péribuccale'].map(i => (
            <li>{i}</li>
          ))}
        </ul>
      </div>
    </div>

    
    <!-- Prof. Assis Filipe -->
    <div class="director-card" style="margin-bottom:36px;">
      <div class="img-frame director-photo">
        <img src="/pptx_images/assis-filipe-portrait.png" alt="Prof. Assis Filipe" style="width:100%;height:100%;object-fit:cover;object-position:center top;" />
      </div>
      <div class="director-bio">
        <div class="dir-badge" style="color:var(--sky500);background:var(--sky50);border-color:var(--sky200);">Coordination Brésil</div>
        <h2 class="dir-name">Prof. Assis Filipe</h2>
        <p class="dir-sub">CTBMF-PhD · Fortaleza, Brésil</p>
        <div class="sky-bar"></div>
        <p class="dir-section-label" style="color:var(--sky500);">Formation académique</p>
        <ul class="dir-list">
          {[
            'Résidence en Chirurgie et Traumatologie Bucco-Maxillo-Faciale — HUOL/UFRN',
            'Spécialiste, CFO & Collège Brésilien de Chirurgie Bucco-Maxillo-Faciale',
            'Docteur et Master en Clinique Dentaire (Chirurgie BMF) — UFC',
            'Postdoctorat en Chirurgie Bucco-Maxillo-Faciale — UFC',
            'Fellowship en Chirurgie Fissure Labio-palatine — Hospital Infantil Albert Sabin (HIAS)',
            'Chirurgien BMF — HIAS · Associação Beija-Flor/FUNFACE · SMILE TRAIN (USA)',
            'Maître de stage en Résidence CTBMF — Hospital Universitário Walter Cantídio · UFC',
          ].map(i => (
            <li><span class="dot" style="background:var(--sky500);"></span>{i}</li>
          ))}
        </ul>
        <p class="dir-section-label" style="color:var(--sky500);">Spécialisation clinique</p>
        <ul class="dir-chips">
          {['Chirurgie orale et maxillo-faciale avancée','Implantologie guidée 3D','Chirurgie fissure labio-palatine','Régénération osseuse et tissus mous'].map(i => (
            <li>{i}</li>
          ))}
        </ul>
      </div>
    </div>

    <div class="cta-banner">
      <div>
        <p style="font-size:.88rem;font-weight:700;color:var(--sky900);margin-bottom:3px;">+ Professeurs invités de haut niveau international</p>
        <p style="font-size:.78rem;color:var(--sl500);">Spécialistes de référence participant à des sessions spécifiques du programme.</p>
      </div>
      <a href="/fr/inscription" class="btn btn-sky btn-lg">S'inscrire →</a>
    </div>
  </div>
</div>

<style>
  .director-card { display:grid; grid-template-columns:210px 1fr; gap:28px; align-items:start; }
  .director-photo { width:210px; height:270px; flex-shrink:0; }
  .director-bio { display:flex; flex-direction:column; }
  .dir-badge { display:inline-block; font-size:.58rem; font-weight:800; letter-spacing:1.4px; text-transform:uppercase; border:1px solid; border-radius:4px; padding:2px 8px; margin-bottom:6px; width:fit-content; }
  .dir-name { font-weight:900; font-size:1.35rem; color:var(--sky900); line-height:1.15; margin-bottom:2px; }
  .dir-sub { font-size:.78rem; color:var(--sl400); margin-bottom:10px; }
  .dir-section-label { font-size:.6rem; font-weight:800; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:7px; margin-top:4px; }
  .dir-list { list-style:none; display:flex; flex-direction:column; gap:5px; margin-bottom:14px; }
  .dir-list li { display:flex; gap:7px; font-size:.76rem; color:var(--sl700); line-height:1.5; }
  .dot { width:4px; height:4px; border-radius:50%; flex-shrink:0; margin-top:6px; }
  .dir-chips { list-style:none; display:flex; flex-wrap:wrap; gap:6px; margin-bottom:4px; }
  .dir-chips li { font-size:.72rem; font-weight:600; color:var(--sky700); background:var(--sky50); border:1px solid var(--sky200); border-radius:20px; padding:3px 10px; }
</style>
</Layout>
