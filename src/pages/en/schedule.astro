---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Schedule – DDX Fortaleza 2026" lang="en">
<div class="sec-dark" style="padding:52px 24px 48px;">
  <div class="container" style="padding:0;">
    <span class="eyebrow-white">Weekly schedule</span>
    <h1 class="page-h1-white" style="margin-top:10px;">Programme schedule</h1>
    <div class="gold-bar"></div>
    <p class="lead-white" style="max-width:600px;">Fortaleza, Brazil · 21.02.2027 – 27.02.2027. Seven days of complete surgical immersion.</p>
  </div>
</div>
<div class="sec-white">
  <div class="section">
    <div style="border:1.5px solid var(--sky100);border-radius:14px;overflow:hidden;margin-bottom:48px;">
      <div class="tl-item"><div class="tl-day" style="background:var(--sky900);">SAT<span style="font-size:1.1rem;font-weight:900;display:block;">6</span>NOV</div><div class="tl-body"><h4>🛬 Arrival in Fortaleza</h4><div class="tl-row"><span class="tl-time">All day</span><span>Free transfer to the hotel from the airport. Hotel details and instructions provided upon registration.</span></div></div></div>
      <div class="tl-item"><div class="tl-day" style="background:var(--sky700);">SUN<span style="font-size:1.1rem;font-weight:900;display:block;">7</span>NOV</div><div class="tl-body"><h4>🌴 Free day + General meeting</h4><div class="tl-row"><span class="tl-time">Morning</span><span>Optional excursion around Fortaleza</span></div><div class="tl-row"><span class="tl-time">19:00</span><span>General meeting: how the course and clinic work</span></div></div></div>
      <div class="tl-item"><div class="tl-day" style="background:var(--sky800);">MON<span style="font-size:1.1rem;font-weight:900;display:block;">8</span>NOV</div><div class="tl-body"><h4>🔬 Full surgical day <span class="badge-basic" style="margin-left:8px;">Guided Implantology</span></h4><div class="tl-row"><span class="tl-time">07:00</span><span>Hotel pick-up</span></div><div class="tl-row"><span class="tl-time">08:00</span><span>Course presentation — staff, assistants and instructors</span></div><div class="tl-row"><span class="tl-time">09:00</span><span>Clinical case presentation (students)</span></div><div class="tl-row"><span class="tl-time">10:00</span><span>1st surgical session</span></div><div class="tl-row"><span class="tl-time">12:00</span><span>2nd session · Lunch (each pair after finishing their 2nd session)</span></div><div class="tl-row"><span class="tl-time">14:00</span><span>3rd surgical session</span></div><div class="tl-row"><span class="tl-time">16:00</span><span>4th surgical session</span></div><div class="tl-row"><span class="tl-time">18:00</span><span>Return to hotel</span></div></div></div>
      <div class="tl-item"><div class="tl-day" style="background:var(--sky800);">TUE<span style="font-size:1.1rem;font-weight:900;display:block;">9</span>NOV</div><div class="tl-body"><h4>🔬 Full surgical day <span class="badge-basic" style="margin-left:8px;">Guided Implantology</span></h4><div class="tl-row"><span class="tl-time">08:00</span><span>Hotel pick-up · 09:00 Case presentation · 10:00 1st session · 12:00 2nd session · 14:00 3rd · 16:00 4th · 18:00 Return</span></div></div></div>
      <div class="tl-item"><div class="tl-day" style="background:var(--sky600);">WED<span style="font-size:1.1rem;font-weight:900;display:block;">10</span>NOV</div><div class="tl-body"><h4>🔷 OneDay OnePiece + Free afternoon <span class="badge-mid" style="margin-left:8px;">Immediate Loading</span></h4><div class="tl-row"><span class="tl-time">08:00</span><span>Hotel pick-up · 09:00 Case presentation · 10:00 1st session — Guided Surgery with Immediate Loading</span></div><div class="tl-row"><span class="tl-time">Afternoon</span><span>🌴 Free afternoon to explore Fortaleza</span></div></div></div>
      <div class="tl-item"><div class="tl-day" style="background:var(--sky800);">THU<span style="font-size:1.1rem;font-weight:900;display:block;">11</span>NOV</div><div class="tl-body"><h4>🦷 All-on-Four day <span class="badge-advanced" style="margin-left:8px;">Advanced</span></h4><div class="tl-row"><span class="tl-time">08:00</span><span>Hotel pick-up · 09:00 Case presentation · 10:00 1st session — All-on-Four surgeries · 14:00 3rd · 16:00 4th · 18:00 Return</span></div></div></div>
      <div class="tl-item"><div class="tl-day" style="background:var(--green);">FRI<span style="font-size:1.1rem;font-weight:900;display:block;">12</span>NOV</div><div class="tl-body"><h4>🏆 All-on-Four · Course finale <span class="badge-advanced" style="margin-left:8px;">Diploma</span></h4><div class="tl-row"><span class="tl-time">08:00</span><span>Hotel pick-up · 09:00 All-on-Four placement (students)</span></div><div class="tl-row"><span class="tl-time">14:00</span><span>🎓 Graduation dinner + Diploma ceremony</span></div><div class="tl-row"><span class="tl-time">16:00</span><span>Return to hotel · 🌴 Free afternoon</span></div></div></div>
      <div class="tl-item" style="border-bottom:none;"><div class="tl-day" style="background:var(--sl700);">SAT<span style="font-size:1.1rem;font-weight:900;display:block;">13</span>NOV</div><div class="tl-body"><h4>✈️ Departure</h4><div class="tl-row"><span class="tl-time">All day</span><span>Free transfer to the airport</span></div></div></div>
    </div>
    <div class="grid-2" style="gap:24px;">
      <div class="cta-banner" style="grid-template-columns:1fr;"><div><h3 style="font-weight:800;font-size:1.05rem;color:var(--sky900);margin-bottom:6px;">📄 Download the full programme</h3><p style="font-size:.84rem;color:var(--sl500);margin-bottom:18px;">Complete schedule and logistics in PDF.</p><a href="/en/download" class="btn btn-dark">⬇ Download PDF</a></div></div>
      <div class="cta-banner" style="grid-template-columns:1fr;"><div><h3 style="font-weight:800;font-size:1.05rem;color:var(--sky900);margin-bottom:6px;">Questions about the schedule?</h3><p style="font-size:.84rem;color:var(--sl500);margin-bottom:18px;">Contact Eduardo Burger directly via WhatsApp.</p><a href="https://wa.me/34678871916" target="_blank" class="btn btn-wa">💬 WhatsApp</a></div></div>
    </div>
  </div>
</div>
</Layout>
