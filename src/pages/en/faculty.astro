---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Faculty – DGIS Fortaleza 2026" lang="en">
<div class="sec-dark" style="padding:52px 24px 48px;">
  <div class="container" style="padding:0;">
    <span class="eyebrow-white">Teaching team</span>
    <h1 class="page-h1-white" style="margin-top:10px;">Programme directors</h1>
    <div class="gold-bar"></div>
    <p class="lead-white" style="max-width:600px;">An internationally recognised team in digital guided implantology and advanced oral surgery.</p>
  </div>
</div>
<div class="sec-white">
  <div class="section">
    <div class="grid-2" style="gap:48px;align-items:start;margin-bottom:64px;padding-bottom:64px;border-bottom:1.5px solid var(--sky100);">
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div class="img-frame"><img src="/pptx_images/image23.jpeg" alt="Dr. Juan Méndez" style="width:100%;height:400px;object-fit:cover;object-position:center top;" /></div>
        <div class="img-frame"><img src="/pptx_images/image8.jpeg" alt="Surgical supervision" style="width:100%;height:180px;object-fit:cover;" /><div class="img-cap">Direct surgical supervision</div></div>
      </div>
      <div>
        <div style="display:inline-block;font-size:.62rem;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--sky700);background:var(--sky50);border:1px solid var(--sky200);border-radius:4px;padding:4px 10px;margin-bottom:12px;">Programme Director</div>
        <h2 style="font-weight:900;font-size:1.9rem;color:var(--sky900);line-height:1.1;margin-bottom:4px;">Dr. Juan Méndez</h2>
        <p style="font-size:.88rem;color:var(--sl400);margin-bottom:24px;">Implantology · Madrid, Spain</p>
        <div class="sky-bar"></div>
        <h3 style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;color:var(--sky700);margin-bottom:12px;margin-top:20px;">Education &amp; Career</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:24px;">
          {['Dentist, Universidad Autónoma de Santo Domingo','Master in Implantology and Oral Rehabilitation — ESORIB, Madrid','Diploma in Periodontics and Implants — Clínica Gingiva, Madrid','University Diploma in Oral and Maxillofacial Implantology — Paris XII','Expert in Periodontal Plastic Surgery — Prof. Massimo de Sanctis, Barcelona','Expert in Bone Regeneration — Prof. Carlo Tinti, Italy','Former Director, International Implantology Programme — CIDESID, Barcelona 2000–2020'].map(i=>(
            <li style="display:flex;gap:10px;font-size:.84rem;color:var(--sl700);line-height:1.6;word-wrap:break-word;"><div style="width:5px;height:5px;background:var(--sky600);border-radius:50%;flex-shrink:0;margin-top:8px;"></div>{i}</li>
          ))}
        </ul>
        <h3 style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;color:var(--sky700);margin-bottom:12px;">Clinical specialisation</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;">
          {['Digital guided surgery with 3D planning','Immediate loading All-on-Four protocols','Guided bone regeneration (GBR)','Advanced periodontal plastic surgery'].map(i=>(
            <li style="display:flex;gap:10px;font-size:.84rem;color:var(--sl700);word-wrap:break-word;"><svg width="15" height="15" style="flex-shrink:0;margin-top:3px;" fill="none" stroke="var(--sky500)" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>{i}</li>
          ))}
        </ul>
      </div>
    </div>
    <div class="grid-2" style="gap:48px;align-items:start;margin-bottom:48px;">
      <div>
        <div style="display:inline-block;font-size:.62rem;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--sky500);background:var(--sky50);border:1px solid var(--sky200);border-radius:4px;padding:4px 10px;margin-bottom:12px;">Brazil Coordinator</div>
        <h2 style="font-weight:900;font-size:1.9rem;color:var(--sky900);line-height:1.1;margin-bottom:4px;">Prof. Assis Filipe</h2>
        <p style="font-size:.88rem;color:var(--sl400);margin-bottom:24px;">CTBMF-PhD · Fortaleza, Brazil</p>
        <div class="sky-bar"></div>
        <h3 style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;color:var(--sky500);margin-bottom:12px;margin-top:20px;">Education &amp; Career</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:24px;">
          {['Residency in Oral & Maxillofacial Surgery / Implantology — HUOL/UFRN','Specialist, CFO & Brazilian College of Oral and Maxillofacial Surgery','PhD and Master in Dental Clinics (Oral & Maxillofacial Surgery) — UFC','Postdoctoral Fellow in Dental Clinics (Oral & Maxillofacial Surgery) — UFC','Fellowship in Cleft Lip and Palate Surgery — Hospital Infantil Albert Sabin (HIAS)','Oral & Maxillofacial Surgeon, Hospital Infantil Albert Sabin (HIAS)','Oral & Maxillofacial Surgeon, Associação Beija-Flor / FUNFACE','Oral & Maxillofacial Surgeon, SMILE TRAIN (Cleft Lip and Palate) — USA','Preceptor, Fellowship in Craniofacial Deformity & Multiprofessional Residency — HIAS','Preceptor, Residency in OMFS, Hospital Universitário Walter Cantídio — UFC'].map(i=>(
            <li style="display:flex;gap:10px;font-size:.84rem;color:var(--sl700);line-height:1.6;word-wrap:break-word;"><div style="width:5px;height:5px;background:var(--sky500);border-radius:50%;flex-shrink:0;margin-top:8px;"></div>{i}</li>
          ))}
        </ul>
        <h3 style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;color:var(--sky500);margin-bottom:12px;">Clinical specialisation</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;">
          {['Advanced oral and maxillofacial surgery','Digital guided implantology with 3D software','Cleft lip and palate surgery','Bone and soft tissue regeneration'].map(i=>(
            <li style="display:flex;gap:10px;font-size:.84rem;color:var(--sl700);word-wrap:break-word;"><svg width="15" height="15" style="flex-shrink:0;margin-top:3px;" fill="none" stroke="var(--sky500)" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>{i}</li>
          ))}
        </ul>
      </div>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div class="img-frame"><img src="/images2/p17_05_642x928.jpeg" alt="Prof. Assis Filipe" style="width:100%;height:400px;object-fit:cover;object-position:center top;" /></div>
        <div class="img-frame"><img src="/pptx_images/image2.jpeg" alt="CliniCare Training" style="width:100%;height:180px;object-fit:cover;" /><div class="img-cap">📍 CliniCare Training · Fortaleza, Brazil</div></div>
      </div>
    </div>
    <div class="cta-banner"><div><p style="font-size:.95rem;font-weight:700;color:var(--sky900);margin-bottom:4px;">+ High-level international guest faculty</p><p style="font-size:.84rem;color:var(--sl500);">Leading specialists who participate in specific sessions throughout the programme.</p></div><a href="/en/registration" class="btn btn-sky btn-lg">Apply now →</a></div>
  </div>
</div>
</Layout>
