---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Download Programme – DDX Fortaleza 2027" lang="en">
<div class="sec-dark" style="padding:52px 24px 48px;">
  <div class="container" style="padding:0;">
    <span class="eyebrow-white">Download</span>
    <h1 class="page-h1-white" style="margin-top:10px;">Full programme PDF</h1>
    <div class="gold-bar"></div>
    <p class="lead-white" style="max-width:600px;">Download all DDX Fortaleza 2027 information in a single PDF document.</p>
  </div>
</div>
<div class="sec-white">
  <div class="section">
    <div class="grid-2" style="gap:48px;align-items:start;">
      <div>
        <div class="card" style="margin-bottom:24px;">
          <div class="card-accent"></div>
          <div class="card-body" style="text-align:center;padding:44px 36px;">
            <div style="font-size:4rem;margin-bottom:16px;">📄</div>
            <h2 style="font-weight:900;font-size:1.4rem;color:var(--sky900);margin-bottom:8px;">DDX Fortaleza 2027</h2>
            <p style="font-size:.88rem;color:var(--sl400);margin-bottom:6px;">Digital Guided Implant Surgery Immersion Program</p>
            <p style="font-size:.8rem;color:var(--sl400);margin-bottom:28px;">Fortaleza, Brazil · 21.02.2027 – 27.02.2027</p>
            <a href="/downloads/DDX-Fortaleza-2026-Programa.pdf" download class="btn btn-sky btn-lg" style="justify-content:center;width:100%;margin-bottom:12px;">⬇ Download PDF</a>
            <a href="/downloads/DDX-Fortaleza-2026-Programa.pdf" target="_blank" class="btn btn-outline" style="justify-content:center;width:100%;">👁 View in browser</a>
          </div>
        </div>
        <div style="background:var(--sky50);border:1px solid var(--sky200);border-radius:10px;padding:20px 24px;">
          <p style="font-size:.82rem;color:var(--sky800);line-height:1.7;"><strong>The PDF includes:</strong> Programme overview, full schedule, surgical techniques, teaching team profiles, venue information and registration instructions.</p>
        </div>
      </div>
      <div>
        <span class="eyebrow">Document contents</span>
        <h2 class="sec-h2" style="margin-top:10px;">What will you find in the PDF?</h2>
        <div class="sky-bar"></div>
        <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:32px;">
          {[
            {n:'01',t:'Programme overview',d:'DDX concept, training objectives and unique surgical immersion methodology.'},
            {n:'02',t:'Full weekly schedule',d:'Day-by-day programme from 21 to 27 February 2027 with all timings.'},
            {n:'03',t:'Surgical techniques',d:'Guided Implantology, OneDay OnePiece and All-on-Four. Detailed description of each protocol.'},
            {n:'04',t:'Teaching team',d:'Full CV of Dr. Juan Méndez and Prof. Assis Filipe. Career and clinical specialisation.'},
            {n:'05',t:'Venue & logistics',d:'CliniCare Training, accommodation, transfers and everything you need to know for travelling.'},
            {n:'06',t:'Registration',d:'Conditions, pricing and the spot reservation process. Direct contact with the coordinator.'},
          ].map(s=>(
            <div style="display:flex;gap:14px;align-items:flex-start;padding:14px;background:#fff;border:1px solid var(--sky100);border-radius:8px;">
              <div style="width:32px;height:32px;background:var(--sky800);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:900;flex-shrink:0;">{s.n}</div>
              <div><div style="font-weight:700;font-size:.88rem;color:var(--sky900);margin-bottom:2px;">{s.t}</div><div style="font-size:.78rem;color:var(--sl500);word-wrap:break-word;">{s.d}</div></div>
            </div>
          ))}
        </div>
        <div class="cta-banner" style="grid-template-columns:1fr;"><div><h3 style="font-weight:800;font-size:1rem;color:var(--sky900);margin-bottom:6px;">Questions after reading it?</h3><p style="font-size:.84rem;color:var(--sl500);margin-bottom:14px;">Message us on WhatsApp — we reply within 24h.</p><a href="https://wa.me/34678871916" target="_blank" class="btn btn-wa">💬 WhatsApp</a></div></div>
      </div>
    </div>
  </div>
</div>
</Layout>
