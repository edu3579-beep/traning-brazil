---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Dirección – DGIS Fortaleza 2026" lang="es">

<div class="sec-dark" style="padding:52px 24px 48px;">
  <div class="container" style="padding:0;">
    <span class="eyebrow-white">Equipo docente</span>
    <h1 class="page-h1-white" style="margin-top:10px;">Dirección del programa</h1>
    <div class="gold-bar"></div>
    <p class="lead-white" style="max-width:600px;">Un equipo de referencia internacional en implantología guiada digital y cirugía oral avanzada.</p>
  </div>
</div>

<div class="sec-white">
  <div class="section">

    <!-- Dr. Juan Méndez -->
    <div class="grid-2" style="gap:48px;align-items:start;margin-bottom:64px;padding-bottom:64px;border-bottom:1.5px solid var(--sky100);">
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div class="img-frame">
          <img src="/pptx_images/image23.jpeg" alt="Dr. Juan Méndez" style="width:100%;height:400px;object-fit:cover;object-position:center top;" />
        </div>
        <div class="img-frame">
          <img src="/pptx_images/image8.jpeg" alt="Dr. Méndez en cirugía" style="width:100%;height:180px;object-fit:cover;" />
          <div class="img-cap">Supervisión quirúrgica directa</div>
        </div>
      </div>
      <div>
        <div style="display:inline-block;font-size:.62rem;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--sky700);background:var(--sky50);border:1px solid var(--sky200);border-radius:4px;padding:4px 10px;margin-bottom:12px;">Director del Programa</div>
        <h2 style="font-weight:900;font-size:1.9rem;color:var(--sky900);line-height:1.1;margin-bottom:4px;">Dr. Juan Méndez</h2>
        <p style="font-size:.88rem;color:var(--sl400);margin-bottom:24px;">Implantología · Madrid, España</p>
        <div class="sky-bar"></div>

        <h3 style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;color:var(--sky700);margin-bottom:12px;margin-top:20px;">Formación académica</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:24px;">
          {[
            'Odontólogo, Universidad Autónoma de Santo Domingo',
            'Máster en Implantología y Rehabilitación Oral — ESORIB, Madrid',
            'Diploma en Periodoncia e Implantes — Clínica Gingiva, Madrid',
            'Diploma Universitario en Implantología Oral y Maxilofacial — Universidad Paris XII',
            'Experto en Cirugía Plástica Periodontal e Implantológica — Prof. Massimo de Sanctis, Barcelona',
            'Experto en Regeneración Ósea y Mucogingival — Prof. Carlo Tinti, Italia',
            'Ex-colaborador docente del Máster en Implantología — Universidad Internacional de Cataluña',
            'Ex-director del Programa Internacional de Implantología — CIDESID, Barcelona 2000–2020',
          ].map(i => (
            <li style="display:flex;gap:10px;font-size:.84rem;color:var(--sl700);line-height:1.6;word-wrap:break-word;">
              <div style="width:5px;height:5px;background:var(--sky600);border-radius:50%;flex-shrink:0;margin-top:8px;"></div>{i}
            </li>
          ))}
        </ul>

        <h3 style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;color:var(--sky700);margin-bottom:12px;">Especialización clínica</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;">
          {[
            'Cirugía guiada digital con planificación 3D',
            'Protocolos de carga inmediata All-on-Four',
            'Regeneración ósea guiada (GBR)',
            'Cirugía plástica periodontal avanzada',
          ].map(i => (
            <li style="display:flex;gap:10px;font-size:.84rem;color:var(--sl700);word-wrap:break-word;">
              <svg width="15" height="15" style="flex-shrink:0;margin-top:3px;" fill="none" stroke="var(--sky500)" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>{i}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Prof. Assis Filipe -->
    <div class="grid-2" style="gap:48px;align-items:start;margin-bottom:48px;">
      <div>
        <div style="display:inline-block;font-size:.62rem;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--sky500);background:var(--sky50);border:1px solid var(--sky200);border-radius:4px;padding:4px 10px;margin-bottom:12px;">Coordinación Brasil</div>
        <h2 style="font-weight:900;font-size:1.9rem;color:var(--sky900);line-height:1.1;margin-bottom:4px;">Prof. Assis Filipe</h2>
        <p style="font-size:.88rem;color:var(--sl400);margin-bottom:24px;">CTBMF-PhD · Fortaleza, Brasil</p>
        <div class="sky-bar"></div>

        <h3 style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;color:var(--sky500);margin-bottom:12px;margin-top:20px;">Formación académica</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:24px;">
          {[
            'Residência em Cirurgia e Traumatologia Buco-Maxilo-Facial/Implantodontia — HUOL/UFRN',
            'Especialista pelo CFO e Colégio Brasileiro de Cirurgia e Traumatologia Buco-Maxilo-Facial',
            'Doutor e Mestre em Clínica Odontológica (Cirurgia Buco-Maxilo-Facial) — UFC',
            'Pós-Doutorando em Clínica Odontológica (Cirurgia Buco-Maxilo-Facial) — UFC',
            'Fellowship em Cirurgia de Fissura Labiopalatina — Hospital Infantil Albert Sabin (HIAS)',
            'Cirurgião Buco-Maxilo-Facial, Hospital Infantil Albert Sabin (HIAS)',
            'Cirurgião Buco-Maxilo-Facial, Associação Beija-Flor/FUNFACE',
            'Cirurgião Buco-Maxilo-Facial, SMILE TRAIN (Cleft Lip and Palate) — EUA',
            'Preceptor do Fellowship em Deformidade Craniofacial e Residência Multiprofissional — HIAS',
            'Preceptor da Residência em CTBMF, Hospital Universitário Walter Cantídio — UFC',
          ].map(i => (
            <li style="display:flex;gap:10px;font-size:.84rem;color:var(--sl700);line-height:1.6;word-wrap:break-word;">
              <div style="width:5px;height:5px;background:var(--sky500);border-radius:50%;flex-shrink:0;margin-top:8px;"></div>{i}
            </li>
          ))}
        </ul>

        <h3 style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;color:var(--sky500);margin-bottom:12px;">Especialización clínica</h3>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:10px;">
          {[
            'Cirugía oral y maxilofacial avanzada',
            'Implantología guiada con software 3D',
            'Cirugía de fisura labiopalatina',
            'Regeneración ósea y tejidos blandos',
          ].map(i => (
            <li style="display:flex;gap:10px;font-size:.84rem;color:var(--sl700);word-wrap:break-word;">
              <svg width="15" height="15" style="flex-shrink:0;margin-top:3px;" fill="none" stroke="var(--sky500)" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>{i}
            </li>
          ))}
        </ul>
      </div>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div class="img-frame">
          <img src="/images2/p17_05_642x928.jpeg" alt="Prof. Assis Filipe" style="width:100%;height:400px;object-fit:cover;object-position:center top;" />
        </div>
        <div class="img-frame">
          <img src="/pptx_images/image2.jpeg" alt="CliniCare Training" style="width:100%;height:180px;object-fit:cover;" />
          <div class="img-cap">📍 CliniCare Training · Fortaleza, Brasil</div>
        </div>
      </div>
    </div>

    <div class="cta-banner">
      <div>
        <p style="font-size:.95rem;font-weight:700;color:var(--sky900);margin-bottom:4px;">+ Profesores invitados de alto nivel internacional</p>
        <p style="font-size:.84rem;color:var(--sl500);">Especialistas de referencia que participan en sesiones específicas del programa.</p>
      </div>
      <a href="/inscripcion" class="btn btn-sky btn-lg">Inscribirme →</a>
    </div>
  </div>
</div>
</Layout>
