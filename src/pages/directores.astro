---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Dirección – DDX Fortaleza 2027" lang="es">

<div class="sec-dark" style="padding:36px 24px 32px;">
  <div class="container" style="padding:0;">
    <span class="eyebrow-white">Equipo docente</span>
    <h1 class="page-h1-white" style="margin-top:8px;">Dirección del programa</h1>
    <div class="gold-bar"></div>
    <p class="lead-white" style="max-width:560px;">Un equipo de referencia internacional en implantología guiada digital y cirugía oral avanzada.</p>
  </div>
</div>

<div class="sec-white">
  <div class="section">

    <!-- ── Dr. Juan Méndez ── -->
    <div class="director-card" style="border-bottom:1.5px solid var(--sky100);padding-bottom:36px;margin-bottom:36px;">
      <div class="director-photo-wrap">
        <div class="img-frame director-photo">
          <img src="/dr-juan-mendez.jpg" alt="Dr. Juan Méndez"
            style="width:100%;height:100%;object-fit:cover;object-position:center top;" />
        </div>
        <div class="dir-photo-name">Dr. Juan Méndez</div>
      </div>
      <div class="director-bio">
        <div class="dir-badge" style="color:var(--sky700);background:var(--sky50);border-color:var(--sky200);">Director del Programa</div>
        <h2 class="dir-name">Dr. Juan Méndez</h2>
        <p class="dir-sub">Implantología · Barcelona, España</p>
        <div class="sky-bar"></div>

        <p class="dir-section-label" style="color:var(--sky700);">Formación académica</p>
        <ul class="dir-list">
          {[
            'Odontólogo, Universidad Autónoma de Santo Domingo',
            'Máster en Implantología y Rehabilitación Oral — ESORIB, Madrid',
            'Diploma en Periodoncia e Implantes — Clínica Gingiva, Madrid',
            'Diploma Universitario en Implantología Oral y Maxilofacial — Universidad Paris XII',
            'Experto en Cirugía Plástica Periodontal e Implantológica — Prof. Massimo de Sanctis, Barcelona',
            'Experto en Regeneración Ósea y Mucogingival — Prof. Carlo Tinti, Italia',
            'Ex-colaborador docente del Máster en Implantología — Universidad Internacional de Cataluña',
            'Ex-director del Programa Internacional de Implantología — CIDESID, Barcelona 2000–2020',
          ].map(i => (
            <li><span class="dot" style="background:var(--sky600);"></span>{i}</li>
          ))}
        </ul>

        <p class="dir-section-label" style="color:var(--sky700);">Especialización clínica</p>
        <ul class="dir-chips">
          {['Cirugía guiada digital 3D','Carga inmediata All-on-Four','Regeneración ósea guiada (GBR)','Cirugía plástica periodontal'].map(i => (
            <li>{i}</li>
          ))}
        </ul>
      </div>
    </div>

    <!--  Dr. Manuel González  -->
    <div class="director-card" style="border-bottom:1.5px solid var(--sky100);padding-bottom:36px;margin-bottom:36px;">
      <div class="director-photo-wrap">
        <div class="img-frame director-photo">
          <img src="/dr-manuel-gonzalez.jpg" alt="Dr. Manuel González"
            style="width:100%;height:100%;object-fit:contain;object-position:center center;" />
        </div>
        <div class="dir-photo-name">Dr. Manuel González</div>
      </div>
      <div class="director-bio">
        <div class="dir-badge" style="color:var(--sky700);background:var(--sky50);border-color:var(--sky200);">Director del Programa</div>
        <h2 class="dir-name">Dr. Manuel González</h2>
        <p class="dir-sub">Odontología · Murcia, España</p>
        <div class="sky-bar"></div>

        <p class="dir-section-label" style="color:var(--sky700);">Formación académica</p>
        <ul class="dir-list">
          {[
            'Licenciado en Odontología, Facultad de Medicina, Murcia (2001)',
            'Máster en Implantología y Prostodoncia — Centro Internacional de Estudios Superiores de Implantología Dental, Universidad Católica de Santo Domingo. Mejor Alumno (2002–2003)',
            'Investigación y desarrollo Implante Tricortical Excalibur (2004–2005) — Conferenciante, SCDO Científica, Barcelona',
            'Máster en Implantología Oral y Prótesis Implantoasistida — Prof. Dr. Raúl Caffsse y Prof. Dr. Jorge Galante, 300 hrs., Elche (2007–2008)',
            'Máster en Envejecimiento: Sanidad, Universidad de Murcia (2015)',
            'Especialista en Estética Peribucal — UCAM, Universidad Católica San Antonio, Murcia (2016)',
            'Máster en Oclusión y Rehabilitación Oral — Prof. Dr. Aníbal Alonso',
            'Experto en Planificación 3D y Cirugía Guiada — Formación Dental Avanzada C3D, Dr. Xulio Pouso',
            'Experto en Exoplan, Bluesky y Codiagnostix',
          ].map(i => (
            <li><span class="dot" style="background:var(--sky600);"></span>{i}</li>
          ))}
        </ul>

        <p class="dir-section-label" style="color:var(--sky700);">Especialización clínica</p>
        <ul class="dir-chips">
          {['Implantología guiada digital','Cirugía guiada 3D','Rehabilitación oral e implantológica','Estética peribucal'].map(i => (
            <li>{i}</li>
          ))}
        </ul>
      </div>
    </div>

    
    <!-- ── Prof. Assis Filipe ── -->
    <div class="director-card" style="margin-bottom:36px;">
      <div class="director-photo-wrap">
        <div class="img-frame director-photo">
          <img src="/pptx_images/assis-filipe-portrait.png" alt="Prof. Assis Filipe"
            style="width:100%;height:100%;object-fit:cover;object-position:center top;" />
        </div>
        <div class="dir-photo-name">Prof. Assis Filipe</div>
      </div>
      <div class="director-bio">
        <div class="dir-badge" style="color:var(--sky500);background:var(--sky50);border-color:var(--sky200);">Coordinación Brasil</div>
        <h2 class="dir-name">Prof. Assis Filipe</h2>
        <p class="dir-sub">CTBMF-PhD · Fortaleza, Brasil</p>
        <div class="sky-bar"></div>

        <p class="dir-section-label" style="color:var(--sky500);">Formación académica</p>
        <ul class="dir-list">
          {[
            'Residência em Cirurgia e Traumatologia Buco-Maxilo-Facial/Implantodontia — HUOL/UFRN',
            'Especialista pelo CFO e Colégio Brasileiro de CTBMF',
            'Doutor e Mestre em Clínica Odontológica — UFC',
            'Pós-Doutorando em Cirurgia Buco-Maxilo-Facial — UFC',
            'Fellowship em Cirurgia de Fissura Labiopalatina — Hospital Infantil Albert Sabin (HIAS)',
            'Cirurgião CTBMF — HIAS · Associação Beija-Flor/FUNFACE · SMILE TRAIN (EUA)',
            'Preceptor da Residência em CTBMF — Hospital Universitário Walter Cantídio · UFC',
          ].map(i => (
            <li><span class="dot" style="background:var(--sky500);"></span>{i}</li>
          ))}
        </ul>

        <p class="dir-section-label" style="color:var(--sky500);">Especialización clínica</p>
        <ul class="dir-chips" style="--chip-color:var(--sky500);">
          {['Cirugía oral y maxilofacial avanzada','Implantología guiada 3D','Cirugía de fisura labiopalatina','Regeneración ósea y tejidos blandos'].map(i => (
            <li>{i}</li>
          ))}
        </ul>
      </div>
    </div>

    <div class="cta-banner">
      <div>
        <p style="font-size:.88rem;font-weight:700;color:var(--sky900);margin-bottom:3px;">+ Profesores invitados de alto nivel internacional</p>
        <p style="font-size:.78rem;color:var(--sl500);">Especialistas de referencia que participan en sesiones específicas del programa.</p>
      </div>
      <a href="/inscripcion" class="btn btn-sky btn-lg">Inscribirme →</a>
    </div>

  </div>
</div>

<style>
  .director-card {
    display: grid;
    grid-template-columns: 210px 1fr;
    gap: 28px;
    align-items: start;
  }
  .director-card > .director-photo-wrap { grid-column: 1; }
  .director-photo-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    width: 210px;
    flex-shrink: 0;
  }
  .director-photo {
    width: 210px;
    height: 270px;
    flex-shrink: 0;
  }
  .dir-photo-name {
    font-size: .82rem;
    font-weight: 800;
    color: var(--sky900);
    text-align: center;
    letter-spacing: .3px;
  }
  .director-bio { display: flex; flex-direction: column; }
  .dir-badge {
    display: inline-block;
    font-size: .58rem;
    font-weight: 800;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    border: 1px solid;
    border-radius: 4px;
    padding: 2px 8px;
    margin-bottom: 6px;
    width: fit-content;
  }
  .dir-name {
    font-weight: 900;
    font-size: 1.35rem;
    color: var(--sky900);
    line-height: 1.15;
    margin-bottom: 2px;
  }
  .dir-sub { font-size: .78rem; color: var(--sl400); margin-bottom: 10px; }
  .dir-section-label {
    font-size: .6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    margin-bottom: 7px;
    margin-top: 4px;
  }
  .dir-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 5px;
    margin-bottom: 14px;
  }
  .dir-list li {
    display: flex;
    gap: 7px;
    font-size: .76rem;
    color: var(--sl700);
    line-height: 1.5;
  }
  .dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 6px;
  }
  .dir-chips {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 4px;
  }
  .dir-chips li {
    font-size: .72rem;
    font-weight: 600;
    color: var(--sky700);
    background: var(--sky50);
    border: 1px solid var(--sky200);
    border-radius: 20px;
    padding: 3px 10px;
  }
  @media (max-width: 680px) {
    .director-card {
      grid-template-columns: 1fr !important;
    }
    .director-photo-wrap {
      width: 180px !important;
    }
    .director-photo {
      width: 180px !important;
      height: 230px !important;
    }
  }
</style>
</Layout>
